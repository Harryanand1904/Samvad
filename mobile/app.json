{
  "expo": {
    "name": "मराठी वाचा",
    "slug": "marathi-vacha",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.samvad.marathivacha",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "मराठीत बोलण्यासाठी मायक्रोफोन वापरला जातो.",
        "NSSpeechRecognitionUsageDescription": "बोललेले शब्द मजकुरात रूपांतरित करण्यासाठी भाषण ओळख वापरली जाते."
      }
    },
    "android": {
      "package": "com.samvad.marathivacha",
      "adaptiveIcon": {
        "backgroundColor": "#8B5319",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "मराठीत बोलण्यासाठी मायक्रोफोन वापरला जातो.",
          "speechRecognitionPermission": "बोललेले शब्द मजकुरात रूपांतरित करण्यासाठी भाषण ओळख वापरली जाते."
        }
      ],
      "expo-font"
    ]
  }
}
